User Function BInclui(cAlias,nReg,nOpc)
	Local nOpcao := 0

	//nOpcao := AxInclui(cAlias,nReg,nOpc)
	If nOpcao == 1
		MsgInfo("Inclusуo efetuada com sucesso!")
	Else
		MsgInfo("Nуo щ permitida a inclusуo")
	Endif

Return Nil


