User Function BAltera(cAlias,nReg,nOpc)
	Local nOpcao := 0
	nOpcao := AxAltera(cAlias,nReg,nOpc)
	If nOpcao == 1
		MsgInfo("Alteraчуo efetuada com sucesso!")
	Else
		MsgInfo("Alteraчуo cancelada!")
	Endif
Return Nil

